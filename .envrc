use flake

# Expose a stable path to the flake's Python environment for the editor's
# language servers. ty reads `tool.ty.environment.python` in pyproject.toml,
# which points at this symlink, so import resolution (requests, watchdog) works
# regardless of PATH/direnv load ordering. Symlink the env *prefix* (not the
# bare interpreter) so ty can find lib/site-packages through it.
ln -sfn "$(dirname "$(dirname "$(command -v python)")")" "$PWD/.direnv/pyenv"
